# Optional: Naver Search Open API. If omitted, the collector uses public Naver Finance pages.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Optional: Dify Workflow API
DIFY_API_KEY=
DIFY_WORKFLOW_URL=https://api.dify.ai/v1/workflows/run
